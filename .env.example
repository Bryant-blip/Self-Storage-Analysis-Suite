# Self Storage Tools — Desktop App Environment Variables
# Copy this file to .env and fill in your keys

# Google Places API key (used for competitor discovery + geocoding)
# Get one at: console.cloud.google.com — enable "Places API" and "Geocoding API"
GOOGLE_PLACES_API_KEY=

# Firecrawl API key (used to scrape facility websites — handles JS + Cloudflare)
# Get one at: firecrawl.dev
FIRECRAWL_API_KEY=

# Anthropic API key (used by Market Comps pricing extraction + Fact-Check + Market Analysis)
# Get one at: console.anthropic.com
ANTHROPIC_API_KEY=

# ── Crexi Watcher ──────────────────────────────────────────────────────────
# Free Crexi account credentials (optional — some fields may be login-gated without them)
CREXI_EMAIL=
CREXI_PASSWORD=

# Market to search (Phase 1: single state; Phase 2: comma-separated list)
CREXI_MARKET=Washington

# ── Watcher Config ─────────────────────────────────────────────────────────
# Max new deals to run the full comps pipeline on per run (protects API quota)
MAX_DEALS_PER_RUN=3

# Max Crexi search result pages to scrape per run (keep at 1 initially)
MAX_SEARCH_PAGES=1

# Comps search radius around each deal address (miles)
DEFAULT_RADIUS_MILES=1.5

# ── Census Population Gate (Stage 2a) ──────────────────────────────────────
# Free Census API key — register at: api.census.gov/data/key_signup.html
# Optional but recommended (raises rate limits). Works without a key too.
CENSUS_API_KEY=

# Minimum summed population across subject ZIP + neighbors (~3 mile buffer) to pass
MIN_POPULATION_3MI=30000

# How many days to cache Census ZIP population lookups before re-querying
POPULATION_CACHE_DAYS=365

# Set to "true" to scrape + parse Crexi without calling the comps pipeline (safe for testing)
DRY_RUN=false
