# Copy this to .env and fill in your values

# Secret key for signing JWT tokens — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Admin email — this user gets access to the admin dashboard
ADMIN_EMAIL=

# Optional: daily search limit per user (default 50)
# DAILY_SEARCH_LIMIT=50

# Optional: database URL (default SQLite local)
# DATABASE_URL=postgresql://user:pass@host/dbname

# No ANTHROPIC_API_KEY needed — each user provides their own at signup
